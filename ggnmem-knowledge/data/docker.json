        {"flag": "--filter", "description": "Filter output"},
        {"flag": "-q", "description": "Only display volume names"}
      ],
      "examples": ["docker volume ls", "docker volume ls --filter dangling=true"],
      "difficulty": 2
    },
    {
      "command": "docker volume create",
      "description": "Create a named Docker volume",
      "category": "volumes",
      "topic": "docker",
      "aliases": ["create volume", "add volume", "new volume"],
      "flags": [
        {"flag": "-d", "description": "Volume driver"},
        {"flag": "--label", "description": "Set metadata labels"}
