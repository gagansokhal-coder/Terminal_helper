      "description": "Display detailed information about a container or image",
      "category": "containers",
      "topic": "docker",
      "aliases": ["inspect container", "container details", "container info", "image details"],
      "flags": [
        {"flag": "--format", "description": "Format output using Go template"},
        {"flag": "--type", "description": "Specify object type (container, image, network)"}
      ],
      "examples": ["docker inspect mycontainer", "docker inspect --format '{{.NetworkSettings.IPAddress}}' mycontainer"],
      "difficulty": 2
    },
    {
