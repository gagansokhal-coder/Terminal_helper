      "topic": "docker",
      "aliases": ["list networks", "show networks", "docker networks"],
      "flags": [
        {"flag": "--filter", "description": "Filter output"},
        {"flag": "--format", "description": "Pretty-print using Go template"}
      ],
      "examples": ["docker network ls", "docker network ls --filter driver=bridge"],
      "difficulty": 2
    },
    {
      "command": "docker network create",
      "description": "Create a new Docker network",
      "category": "networking",
      "topic": "docker",
      "aliases": ["create network", "add network", "new network"],
      "flags": [
        {"flag": "-d", "description": "Network driver (bridge, overlay, host)"},
        {"flag": "--subnet", "description": "Subnet in CIDR format"}
      ],
      "examples": ["docker network create mynetwork", "docker network create -d overlay myoverlay"],
      "difficulty": 2
    },
    {
