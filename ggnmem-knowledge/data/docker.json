      "description": "Remove one or more Docker images",
      "category": "images",
      "topic": "docker",
      "aliases": ["remove image", "delete image", "clean up images"],
      "flags": [
        {"flag": "-f", "description": "Force removal"}
      ],
      "examples": ["docker rmi myimage", "docker rmi $(docker images -q --filter 'dangling=true')"],
      "difficulty": 1
    },
    {
