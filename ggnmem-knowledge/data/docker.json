      "description": "Create a tag for an image",
      "category": "images",
      "topic": "docker",
      "aliases": ["tag image", "rename image", "label image"],
      "flags": [],
      "examples": ["docker tag myapp myrepo/myapp:v1.0", "docker tag abc123 myapp:latest"],
      "difficulty": 2
    },
    {
      "command": "docker compose ps",
      "description": "List compose service containers and their status",
      "category": "compose",
      "topic": "docker",
      "aliases": ["compose status", "compose containers", "service status"],
