      "topic": "docker",
      "aliases": ["copy to container", "copy from container", "transfer files container"],
      "flags": [],
      "examples": ["docker cp myfile.txt mycontainer:/app/", "docker cp mycontainer:/app/log.txt ./log.txt"],
      "difficulty": 2
    },
