{
  "topic": "docker",
  "description": "Docker container management and orchestration",
  "version": "1.0",
  "entries": [
    {
      "command": "docker ps",
      "description": "List running containers",
      "category": "containers",
      "topic": "docker",
      "aliases": ["show running containers", "list containers", "what containers are running", "active containers"],
      "flags": [
        {"flag": "-a", "description": "Show all containers (including stopped)"},
        {"flag": "-q", "description": "Only display container IDs"},
        {"flag": "--format", "description": "Pretty-print using Go template"},
        {"flag": "-f", "description": "Filter output based on conditions"},
        {"flag": "--no-trunc", "description": "Don't truncate output"}
      ],
      "examples": ["docker ps", "docker ps -a", "docker ps -q", "docker ps --format '{{.Names}}: {{.Status}}'"],
      "difficulty": 1
    },
    {
      "command": "docker images",
      "description": "List locally available Docker images",
      "category": "images",
      "topic": "docker",
      "aliases": ["show docker images", "list images", "what images are available", "local images"],
      "flags": [
        {"flag": "-a", "description": "Show all images (including intermediate)"},
        {"flag": "-q", "description": "Only show image IDs"},
        {"flag": "--filter", "description": "Filter output"},
        {"flag": "--format", "description": "Pretty-print using Go template"}
      ],
      "examples": ["docker images", "docker images -a", "docker images --filter 'dangling=true'"],
      "difficulty": 1
    },
    {
      "command": "docker run",
      "description": "Create and start a new container from an image",
      "category": "containers",
      "topic": "docker",
      "aliases": ["start container", "run container", "create and run container", "launch container"],
      "flags": [
        {"flag": "-d", "description": "Run in detached (background) mode"},
        {"flag": "-it", "description": "Interactive mode with TTY"},
        {"flag": "-p", "description": "Map host port to container port"},
        {"flag": "-v", "description": "Mount a volume"},
        {"flag": "--name", "description": "Assign a name to the container"},
        {"flag": "--rm", "description": "Remove container when it stops"},
        {"flag": "-e", "description": "Set environment variable"}
      ],
      "examples": ["docker run -d -p 8080:80 nginx", "docker run -it ubuntu bash", "docker run --rm --name myapp myimage"],
      "difficulty": 1
    },
    {
      "command": "docker stop",
      "description": "Stop one or more running containers",
      "category": "containers",
      "topic": "docker",
      "aliases": ["stop container", "halt container", "shutdown container"],
      "flags": [
        {"flag": "-t", "description": "Seconds to wait before killing"}
      ],
      "examples": ["docker stop mycontainer", "docker stop $(docker ps -q)"],
      "difficulty": 1
    },
    {
      "command": "docker rm",
      "description": "Remove one or more stopped containers",
      "category": "containers",
      "topic": "docker",
      "aliases": ["remove container", "delete container", "clean up containers"],
      "flags": [
        {"flag": "-f", "description": "Force remove (even if running)"},
        {"flag": "-v", "description": "Remove associated volumes"}
      ],
      "examples": ["docker rm mycontainer", "docker rm -f mycontainer", "docker rm $(docker ps -aq)"],
      "difficulty": 1
    },
    {
      "command": "docker build",
      "description": "Build a Docker image from a Dockerfile",
      "category": "images",
      "topic": "docker",
      "aliases": ["build image", "create image", "build docker image", "build from dockerfile"],
      "flags": [
        {"flag": "-t", "description": "Tag the image (name:tag)"},
        {"flag": "-f", "description": "Specify Dockerfile path"},
        {"flag": "--no-cache", "description": "Build without using cache"},
        {"flag": "--build-arg", "description": "Set build-time variables"}
      ],
      "examples": ["docker build -t myapp .", "docker build -t myapp:v1.0 -f Dockerfile.prod ."],
      "difficulty": 1
    },
    {
      "command": "docker pull",
      "description": "Download an image from a registry",
      "category": "images",
      "topic": "docker",
      "aliases": ["download image", "fetch image", "pull image"],
      "flags": [
        {"flag": "--platform", "description": "Set platform (linux/amd64, linux/arm64)"}
      ],
      "examples": ["docker pull nginx", "docker pull ubuntu:22.04", "docker pull --platform linux/arm64 node"],
      "difficulty": 1
    },
    {
      "command": "docker push",
      "description": "Upload an image to a registry",
      "category": "images",
      "topic": "docker",
      "aliases": ["upload image", "push image", "publish image"],
      "flags": [],
      "examples": ["docker push myrepo/myapp:latest"],
      "difficulty": 2
    },
    {
      "command": "docker logs",
      "description": "Fetch the logs of a container",
      "category": "containers",
      "topic": "docker",
      "aliases": ["show container logs", "view logs", "container output", "check container logs"],
      "flags": [
        {"flag": "-f", "description": "Follow log output (tail -f)"},
        {"flag": "--tail", "description": "Number of lines to show from end"},
        {"flag": "--since", "description": "Show logs since timestamp"},
        {"flag": "-t", "description": "Show timestamps"}
      ],
      "examples": ["docker logs mycontainer", "docker logs -f mycontainer", "docker logs --tail 100 mycontainer"],
      "difficulty": 1
    },
    {
      "command": "docker exec",
      "description": "Run a command inside a running container",
      "category": "containers",
      "topic": "docker",
      "aliases": ["execute in container", "run command in container", "shell into container", "enter container"],
      "flags": [
        {"flag": "-it", "description": "Interactive mode with TTY"},
        {"flag": "-d", "description": "Run in detached mode"},
        {"flag": "-u", "description": "Specify username or UID"},
        {"flag": "-w", "description": "Working directory inside container"}
      ],
      "examples": ["docker exec -it mycontainer bash", "docker exec mycontainer ls /app", "docker exec -it mycontainer sh"],
      "difficulty": 1
    },
    {
