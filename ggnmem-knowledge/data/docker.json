      "description": "Start all services defined in docker-compose.yml",
      "category": "compose",
      "topic": "docker",
      "aliases": ["start compose", "start docker compose", "launch services", "bring up services", "start all services"],
      "flags": [
        {"flag": "-d", "description": "Run in detached mode"},
        {"flag": "--build", "description": "Build images before starting"},
        {"flag": "--force-recreate", "description": "Recreate containers even if unchanged"},
        {"flag": "--scale", "description": "Scale a service to N instances"}
      ],
      "examples": ["docker compose up -d", "docker compose up --build", "docker compose up -d --force-recreate"],
      "difficulty": 1
    },
    {
      "command": "docker compose down",
      "description": "Stop and remove all compose services, networks, and volumes",
      "category": "compose",
      "topic": "docker",
      "aliases": ["stop compose", "stop all services", "tear down services", "shutdown compose"],
      "flags": [
        {"flag": "-v", "description": "Remove named volumes"},
        {"flag": "--rmi all", "description": "Remove all images used by services"}
      ],
      "examples": ["docker compose down", "docker compose down -v", "docker compose down --rmi all"],
      "difficulty": 1
    },
    {
      "command": "docker compose logs",
      "description": "View output from compose services",
      "category": "compose",
      "topic": "docker",
      "aliases": ["compose logs", "service logs", "view compose logs"],
      "flags": [
        {"flag": "-f", "description": "Follow log output"},
        {"flag": "--tail", "description": "Number of lines from end"}
      ],
      "examples": ["docker compose logs", "docker compose logs -f web", "docker compose logs --tail 50"],
      "difficulty": 1
    },
    {
