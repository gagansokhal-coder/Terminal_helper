      "category": "files",
      "topic": "linux",
      "aliases": ["list files", "show files", "directory listing", "what files are here"],
      "flags": [
        {"flag": "-l", "description": "Long format with details"},
        {"flag": "-a", "description": "Show hidden files"},
        {"flag": "-h", "description": "Human-readable file sizes"},
        {"flag": "-R", "description": "Recursive listing"},
        {"flag": "-t", "description": "Sort by modification time"}
      ],
      "examples": ["ls", "ls -la", "ls -lah", "ls -lt"],
      "difficulty": 1
    },
    {
