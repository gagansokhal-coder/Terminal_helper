        {"flag": "-R", "description": "Apply recursively"},
        {"flag": "-v", "description": "Verbose output"}
      ],
      "examples": ["chown user:group file.txt", "chown -R www-data:www-data /var/www/"],
      "difficulty": 2
    },
    {
