      "description": "Change the current working directory",
      "category": "files",
      "topic": "linux",
      "aliases": ["change directory", "go to directory", "navigate to folder"],
      "flags": [],
      "examples": ["cd /var/log", "cd ~", "cd ..", "cd -"],
      "difficulty": 1
    },
    {
      "command": "pwd",
      "description": "Print the current working directory",
      "category": "files",
      "topic": "linux",
      "aliases": ["current directory", "where am I", "show current path", "print working directory"],
      "flags": [],
      "examples": ["pwd"],
      "difficulty": 1
    },
    {
      "command": "cat",
      "description": "Display file contents",
      "category": "files",
      "topic": "linux",
      "aliases": ["show file contents", "read file", "display file", "view file"],
      "flags": [
        {"flag": "-n", "description": "Number all output lines"},
        {"flag": "-b", "description": "Number non-blank lines"}
      ],
      "examples": ["cat file.txt", "cat -n file.txt", "cat file1.txt file2.txt"],
      "difficulty": 1
    },
    {
      "command": "grep",
      "description": "Search for patterns in files or input",
      "category": "text",
      "topic": "linux",
      "aliases": ["search in files", "find text", "search pattern", "find string in file"],
      "flags": [
        {"flag": "-r", "description": "Recursive search"},
        {"flag": "-i", "description": "Case-insensitive search"},
        {"flag": "-n", "description": "Show line numbers"},
        {"flag": "-l", "description": "Show only filenames"},
        {"flag": "-v", "description": "Invert match"},
        {"flag": "-c", "description": "Count matching lines"}
      ],
      "examples": ["grep 'error' log.txt", "grep -rn 'TODO' src/", "grep -i 'warning' *.log"],
      "difficulty": 1
    },
    {
      "command": "find",
      "description": "Search for files in a directory hierarchy",
      "category": "files",
      "topic": "linux",
      "aliases": ["find files", "search for file", "locate file", "find by name"],
      "flags": [
        {"flag": "-name", "description": "Search by filename pattern"},
        {"flag": "-type", "description": "Filter by type (f=file, d=directory)"},
        {"flag": "-size", "description": "Filter by size"},
        {"flag": "-mtime", "description": "Filter by modification time"},
        {"flag": "-exec", "description": "Execute command on results"}
      ],
      "examples": ["find . -name '*.rs'", "find /var -type f -size +100M", "find . -name '*.log' -mtime +30 -delete"],
      "difficulty": 1
    },
    {
