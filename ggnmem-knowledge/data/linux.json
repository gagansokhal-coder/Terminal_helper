        {"flag": "-r", "description": "Copy directories recursively"},
        {"flag": "-v", "description": "Verbose output"},
        {"flag": "-i", "description": "Prompt before overwrite"},
        {"flag": "-p", "description": "Preserve permissions and timestamps"}
