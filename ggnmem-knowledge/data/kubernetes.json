  "version": "1.0",
  "entries": [
    {
      "command": "kubectl get pods",
      "description": "List all pods in the current namespace",
      "category": "pods",
      "topic": "kubernetes",
      "aliases": ["show pods", "list pods", "running pods", "what pods are running", "k8s pods"],
      "flags": [
        {"flag": "-A", "description": "All namespaces"},
        {"flag": "-n", "description": "Specific namespace"},
        {"flag": "-o wide", "description": "Show extra info (node, IP)"},
        {"flag": "-o yaml", "description": "Output as YAML"},
        {"flag": "-o json", "description": "Output as JSON"},
        {"flag": "-l", "description": "Filter by label selector"},
        {"flag": "-w", "description": "Watch for changes"}
      ],
      "examples": ["kubectl get pods", "kubectl get pods -A", "kubectl get pods -n production", "kubectl get pods -o wide"],
      "difficulty": 1
    },
    {
